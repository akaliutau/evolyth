def leaderboard(runs: list[RunView], limit: int = 8) -> list[RunView]:
    rows = [r for r in runs if r.status == "succeeded"] or runs
    return sorted(rows, key=lambda r: r.score, reverse=True)[:limit]


def pareto_front(runs: list[RunView]) -> set[str]:
    ids: set[str] = set()
    candidate_runs = [r for r in runs if r.status == "succeeded"] or runs
    for a in candidate_runs:
        dominated = False
        for b in candidate_runs:
            if a.run_id == b.run_id:
                continue
            if _dominates(b, a):
                dominated = True
                break
        if not dominated and a.run_id:
            ids.add(a.run_id)
    return ids


def _dominates(a: RunView, b: RunView) -> bool:
    max_keys = ["score", "val_accuracy"]
    min_keys = ["parameter_count", "model_bytes", "latency_ms"]
    better_or_equal = True
    strictly_better = False

    for key in max_keys:
        av = _float(a.data.get(key), -math.inf)
        bv = _float(b.data.get(key), -math.inf)
        if av < bv:
            better_or_equal = False
        if av > bv:
            strictly_better = True

    for key in min_keys:
        av = _float(a.data.get(key), math.inf)
        bv = _float(b.data.get(key), math.inf)
        if av > bv:
            better_or_equal = False
        if av < bv:
            strictly_better = True

    return better_or_equal and strictly_better


def recent_actions(snapshot: ArenaSnapshot, limit: int = 24) -> list[dict[str, Any]]:
    actions: list[dict[str, Any]] = []

    for event in snapshot.audit_events[-80:]:
        if event.get("event") == "run_registered":
            actions.append(
                {
                    "ts": event.get("completed_at") or event.get("created_at"),
                    "actor": "store",
                    "title": f"registered {event.get('run_id')}",
                    "detail": f"score={_fmt(event.get('score'))} status={event.get('status')} mutation={event.get('mutation_type')}",
                    "run_id": event.get("run_id"),
                }
            )

    for run in snapshot.runs:
        for event in run.events[-12:]:
            title = str(event.get("event") or event.get("type") or "event")
            detail_bits = []
            for key in ["epoch", "loss", "val_accuracy", "score", "phase", "action", "message"]:
                if key in event:
                    detail_bits.append(f"{key}={_fmt(event.get(key))}")
            actions.append(
                {
                    "ts": event.get("time") or event.get("timestamp") or run.data.get("completed_at") or run.data.get("created_at"),
                    "actor": "executor",
                    "title": f"{run.run_id}: {title}",
                    "detail": "  ".join(detail_bits) or _short_json(event),
                    "run_id": run.run_id,
                }
            )
        if run.review:
            actions.append(
                {
                    "ts": run.data.get("completed_at") or run.data.get("created_at"),
                    "actor": "reviewer",
                    "title": f"reviewed {run.run_id}: {run.review.get('branch_recommendation', 'decision')}",
                    "detail": f"confidence={_fmt(run.review.get('confidence'))} improvement={run.review.get('is_improvement')}",
                    "run_id": run.run_id,
                }
            )

    for item in snapshot.queue[:80]:
        actions.append(
            {
                "ts": item.get("created_at"),
                "actor": "queue",
                "title": f"{item.get('status', 'queued')} {item.get('item_id', '')}",
                "detail": f"p={_fmt(item.get('priority'))} from={item.get('source_run_id')} type={item.get('mutation_type')}",
                "run_id": item.get("source_run_id"),
            }
        )

    actions.sort(key=lambda a: (_parse_ts(a.get("ts")), str(a.get("title"))), reverse=True)
    return actions[:limit]


