def run_dashboard(arena: str | Path, *, host: str = "127.0.0.1", port: int = 8080, poll_s: float = 1.0, title: str = "AI Evolver Live") -> None:
    try:
        from nicegui import ui
    except ModuleNotFoundError as exc:  # pragma: no cover - only hit at runtime without nicegui
        raise SystemExit("NiceGUI is required for the demo UI. Install with: pip install nicegui") from exc

    bus = FileEventBus(arena)
    initial_snapshot, _ = bus.poll(force=True)
    state: dict[str, Any] = {
        "snapshot": initial_snapshot,
        "selected_run_id": initial_snapshot.latest_run.run_id if initial_snapshot.latest_run else None,
        "last_changed": time.time(),
    }

    ui.dark_mode().enable()
    ui.add_head_html(f"<style>{DASHBOARD_CSS}</style>")

    def set_selected(run_id: str | None) -> None:
        state["selected_run_id"] = run_id
        dashboard.refresh()

    async def tick() -> None:
        snapshot, changed = bus.poll()
        if changed:
            old_latest = state["snapshot"].latest_run.run_id if state["snapshot"].latest_run else None
            new_latest = snapshot.latest_run.run_id if snapshot.latest_run else None
            state["snapshot"] = snapshot
            state["last_changed"] = time.time()
            if state.get("selected_run_id") in (None, old_latest):
                state["selected_run_id"] = new_latest
            dashboard.refresh()

    @ui.page("/")
    def index() -> None:
        ui.timer(poll_s, tick)
        with ui.column().classes("evo-page w-full gap-5 px-5 py-5 md:px-8 md:py-7"):
            with ui.row().classes("w-full items-center justify-between gap-4"):
                with ui.column().classes("gap-1"):
                    ui.label("AI Evolver // live arena").classes("text-3xl md:text-5xl font-black neon tracking-tight")
                    ui.label("read-only branch telemetry from manifests, metrics, reviews, queue and JSONL events").classes("tiny")
                with ui.row().classes("items-center gap-2"):
                    ui.html('<span class="pill good"><span style="width:7px;height:7px;border-radius:50%;background:#34d399;box-shadow:0 0 10px #34d399"></span>watching filesystem</span>')
                    ui.label(str(Path(arena).expanduser().resolve())).classes("mono tiny")
            dashboard()

    @ui.refreshable
    def dashboard() -> None:
        snapshot: ArenaSnapshot = state["snapshot"]
        selected_id = state.get("selected_run_id")
        if selected_id not in snapshot.runs_by_id:
            selected_id = snapshot.latest_run.run_id if snapshot.latest_run else None
            state["selected_run_id"] = selected_id
        selected = snapshot.runs_by_id.get(selected_id) if selected_id else snapshot.latest_run

        render_top_stats(snapshot)

        with ui.grid(columns=12).classes("w-full gap-5"):
            with ui.card().classes("glass col-span-12 xl:col-span-8 rounded-[28px] p-4"):
                with ui.row().classes("w-full justify-between items-center mb-2"):
                    with ui.column().classes("gap-0"):
                        ui.label("branch constellation").classes("text-lg font-bold")
                        ui.label("new children appear as glowing nodes; Pareto nodes get a green orbit").classes("tiny")
                    ui.select(
                        options=[r.run_id for r in reversed(snapshot.runs[-40:])],
                        value=selected_id,
                        label="inspect run",
                        on_change=lambda e: set_selected(e.value),
                    ).props("dense outlined dark").classes("w-56")
                ui.html(render_branch_svg(snapshot, selected_id)).classes("w-full")

            with ui.card().classes("glass col-span-12 xl:col-span-4 rounded-[28px] p-5"):
                render_decision_panel(selected)

        with ui.grid(columns=12).classes("w-full gap-5"):
            with ui.card().classes("glass col-span-12 lg:col-span-7 rounded-[28px] p-4"):
                with ui.row().classes("w-full justify-between items-center mb-2"):
                    ui.label("score skyline").classes("text-lg font-bold")
                    ui.html(f'<span class="pill">rev {snapshot.revision} · refreshed {_ago(state["last_changed"])} ago</span>')
                ui.html(render_score_svg(snapshot.runs)).classes("w-full")

            with ui.card().classes("glass col-span-12 lg:col-span-5 rounded-[28px] p-4"):
                render_metric_strip(selected)

        with ui.grid(columns=12).classes("w-full gap-5"):
            with ui.card().classes("glass col-span-12 xl:col-span-7 rounded-[28px] p-4"):
                render_leaderboard(snapshot)
            with ui.card().classes("glass col-span-12 xl:col-span-5 rounded-[28px] p-4"):
                render_queue(snapshot)

        with ui.grid(columns=12).classes("w-full gap-5"):
            with ui.card().classes("glass col-span-12 xl:col-span-6 rounded-[28px] p-4"):
                render_actions(snapshot)
            with ui.card().classes("glass col-span-12 xl:col-span-6 rounded-[28px] p-4"):
                render_run_detail(selected)

    def render_top_stats(snapshot: ArenaSnapshot) -> None:
        runs = snapshot.runs
        succeeded = sum(1 for r in runs if r.status == "succeeded")
        failed = sum(1 for r in runs if r.status == "failed")
        queued = sum(1 for q in snapshot.queue if q.get("status") == "queued")
        running = sum(1 for q in snapshot.queue if q.get("status") == "running") + sum(1 for r in runs if r.status in {"created", "running", "unknown"})
        best = snapshot.best_run
        latest = snapshot.latest_run
        stats = [
            ("runs", len(runs), "registered branches", "good"),
            ("best score", _fmt(best.score if best else None), best.run_id if best else "no score yet", "good"),
            ("queue", queued, f"{running} running · {len(snapshot.queue)} total", "warn"),
            ("failed", failed, f"{succeeded} succeeded", "bad" if failed else "good"),
            ("latest", _short_run(latest.run_id) if latest else "—", latest.status if latest else "waiting", "good"),
        ]
        with ui.grid(columns=5).classes("w-full gap-4"):
            for label, value, sub, tone in stats:
                with ui.card().classes("stat-card col-span-5 sm:col-span-1"):
                    ui.label(str(value)).classes("stat-value neon mono" if label in {"best score", "latest"} else "stat-value mono")
                    ui.label(label).classes("stat-label")
                    ui.html(f'<span class="pill {tone}">{html.escape(str(sub))}</span>')

    def render_decision_panel(run: RunView | None) -> None:
        ui.label("decision cockpit").classes("text-lg font-bold")
        if not run:
            ui.label("No run selected.").classes("tiny")
            return
        review = run.review
        recommendation = review.get("branch_recommendation") or ("continue" if run.status == "succeeded" else "investigate")
        confidence = review.get("confidence")
        improvement = review.get("is_improvement")
        tone = "good" if recommendation in {"continue", "exploit", "retry"} or improvement is True else "warn" if run.status != "failed" else "bad"
        ui.html(f'<div class="pill {tone} mono">{html.escape(str(recommendation))} · confidence {_fmt(confidence)}</div>').classes("my-2")
        with ui.column().classes("gap-3 mt-3"):
            _mini_block("run", f"{run.run_id} · {run.status} · gen {run.generation}")
            _mini_block("mutation", str(run.data.get("mutation_summary") or run.data.get("mutation_type") or "—"))
            _mini_block("observation", str(review.get("observation") or run.data.get("observation") or "No review observation yet."), clamp=True)
            _mini_block("next belief", str(review.get("next_belief") or run.data.get("next_belief") or "No next belief yet."), clamp=True)
        recs = _as_list(review.get("recommended_next_mutations"))[:3]
        if recs:
            ui.label("recommended branches").classes("mt-4 text-sm font-bold text-slate-200")
            for rec in recs:
                ui.html(
                    '<div class="mt-2 p-3 rounded-xl" style="background:rgba(2,6,23,.34);border:1px solid rgba(148,163,184,.10)">'
                    f'<div class="pill warn mono">p={html.escape(_fmt(rec.get("priority")))} · {html.escape(str(rec.get("mutation_type") or "mutation"))}</div>'
                    f'<div class="tiny mt-2" style="color:#cbd5e1">{html.escape(str(rec.get("description") or rec.get("proposed_mutation") or ""))}</div>'
                    '</div>'
                )

    def render_metric_strip(run: RunView | None) -> None:
        ui.label("selected branch metrics").classes("text-lg font-bold mb-2")
        if not run:
            ui.label("No metrics yet.").classes("tiny")
            return
        metrics = [
            ("score", run.data.get("score")),
            ("val acc", run.data.get("val_accuracy")),
            ("loss", run.data.get("val_loss")),
            ("params", run.data.get("parameter_count")),
            ("bytes", run.data.get("model_bytes")),
            ("lat ms", run.data.get("latency_ms")),
            ("train s", run.data.get("train_seconds")),
            ("dry run", run.data.get("dry_run_passed")),
        ]
        with ui.grid(columns=4).classes("w-full gap-3"):
            for label, value in metrics:
                with ui.column().classes("gap-0 p-3 rounded-2xl").style("background:rgba(2,6,23,.34);border:1px solid rgba(148,163,184,.10)"):
                    ui.label(_fmt(value)).classes("mono text-xl font-black text-cyan-100")
                    ui.label(label).classes("tiny uppercase tracking-widest")

    def render_leaderboard(snapshot: ArenaSnapshot) -> None:
        ui.label("leaderboard / Pareto hints").classes("text-lg font-bold mb-2")
        pareto = pareto_front(snapshot.runs)
        rows = []
        for idx, run in enumerate(leaderboard(snapshot.runs, limit=10), 1):
            rows.append(
                {
                    "#": idx,
                    "run": run.run_id,
                    "status": run.status,
                    "score": _fmt(run.score),
                    "acc": _fmt(run.data.get("val_accuracy")),
                    "params": _compact(run.data.get("parameter_count")),
                    "ms": _fmt(run.data.get("latency_ms")),
                    "pareto": "✦" if run.run_id in pareto else "",
                    "idea": _clip(str(run.data.get("mutation_summary") or run.data.get("mutation_type") or ""), 64),
                }
            )
        if not rows:
            ui.label("No runs yet.").classes("tiny")
            return
        ui.table(
            columns=[
                {"name": "#", "label": "#", "field": "#", "align": "left"},
                {"name": "run", "label": "run", "field": "run", "align": "left"},
                {"name": "score", "label": "score", "field": "score", "align": "right"},
                {"name": "acc", "label": "acc", "field": "acc", "align": "right"},
                {"name": "params", "label": "params", "field": "params", "align": "right"},
                {"name": "ms", "label": "ms", "field": "ms", "align": "right"},
                {"name": "pareto", "label": "P", "field": "pareto", "align": "center"},
                {"name": "idea", "label": "idea", "field": "idea", "align": "left"},
            ],
            rows=rows,
            row_key="run",
        ).props("flat dense hide-bottom dark").classes("w-full mono")

    def render_queue(snapshot: ArenaSnapshot) -> None:
        ui.label("mutation queue").classes("text-lg font-bold mb-2")
        active = [q for q in snapshot.queue if q.get("status") in {"queued", "running"}]
        done = len([q for q in snapshot.queue if q.get("status") == "done"])
        ui.html(f'<span class="pill warn">{len(active)} active · {done} done · {len(snapshot.queue)} total</span>').classes("mb-2")
        if not active:
            ui.label("Queue is empty or all items are done.").classes("tiny")
            return
        for item in active[:7]:
            status = item.get("status") or "queued"
            tone = "good" if status == "running" else "warn"
            ui.html(
                '<div class="mt-3 p-3 rounded-2xl" style="background:rgba(2,6,23,.34);border:1px solid rgba(148,163,184,.10)">'
                f'<div class="pill {tone} mono">{html.escape(str(status))} · p={html.escape(_fmt(item.get("priority")))} · {html.escape(str(item.get("mutation_type") or "mutation"))}</div>'
                f'<div class="tiny mt-2">from {html.escape(str(item.get("source_run_id") or "—"))} · {html.escape(str(item.get("item_id") or ""))}</div>'
                f'<div style="color:#dbeafe;font-size:.86rem;margin-top:.35rem;line-height:1.35">{html.escape(_clip(str(item.get("proposed_mutation") or ""), 220))}</div>'
                '</div>'
            )

    def render_actions(snapshot: ArenaSnapshot) -> None:
        ui.label("agent / executor / reviewer stream").classes("text-lg font-bold mb-3")
        actions = recent_actions(snapshot, limit=26)
        if not actions:
            ui.label("No events yet. Events from JSONL files will appear here as the loop runs.").classes("tiny")
            return
        with ui.column().classes("gap-3 max-h-[620px] overflow-y-auto pr-2"):
            for action in actions:
                actor = html.escape(str(action.get("actor") or "event"))
                with ui.row().classes("w-full gap-3 items-start"):
                    ui.html(f'<span class="action-dot {actor}"></span>').classes("mt-2")
                    with ui.column().classes("gap-0 action-line"):
                        ui.label(str(action.get("title") or "event")).classes("font-semibold text-slate-100")
                        ui.label(str(action.get("detail") or "")).classes("tiny")
                        ui.label(f"{actor} · {_ago_ts(action.get('ts'))}").classes("tiny mono")

    def render_run_detail(run: RunView | None) -> None:
        ui.label("branch dossier").classes("text-lg font-bold mb-3")
        if not run:
            ui.label("Select a run to inspect its dossier.").classes("tiny")
            return
        badges = [
            f"status={run.status}",
            f"parent={run.parent_id or 'root'}",
            f"gen={run.generation}",
            f"type={run.data.get('mutation_type') or 'unknown'}",
        ]
        ui.html(" ".join(f'<span class="pill mono">{html.escape(b)}</span>' for b in badges))
        with ui.column().classes("gap-3 mt-4"):
            _mini_block("hypothesis", str(run.data.get("hypothesis") or run.mutation.get("hypothesis") or "—"), clamp=True)
            _mini_block("summary", str(run.data.get("mutation_summary") or run.mutation.get("mutation_summary") or "—"), clamp=True)
            if run.data.get("error_type"):
                _mini_block("error", str(run.data.get("error_type")), clamp=True)
            paths = [
                ("manifest", Path(str(run.data.get("artifact_path") or "")) / "manifest.json"),
                ("metrics", Path(str(run.data.get("metrics_path") or ""))),
                ("events", Path(str(run.data.get("events_path") or ""))),
                ("review", Path(str(run.data.get("artifact_path") or "")) / "ds_review.json"),
            ]
            path_html = "".join(
                f'<div class="tiny mono">{html.escape(label)}: {html.escape(str(path))}</div>'
                for label, path in paths
                if str(path) not in {".", ""}
            )
            ui.html(f'<div class="mt-1 p-3 rounded-xl" style="background:rgba(2,6,23,.28)">{path_html}</div>')

    def _mini_block(label: str, value: str, *, clamp: bool = False) -> None:
        safe_value = html.escape(value or "—")
        max_height = "max-height:7.5rem;overflow:hidden" if clamp else ""
        ui.html(
            f'<div class="p-3 rounded-2xl" style="background:rgba(2,6,23,.34);border:1px solid rgba(148,163,184,.10)">'
            f'<div class="tiny uppercase tracking-widest">{html.escape(label)}</div>'
            f'<div style="color:#e2e8f0;line-height:1.38;font-size:.88rem;{max_height}">{safe_value}</div>'
            '</div>'
        )

    ui.run(host=host, port=port, title=title, favicon="🧬", reload=False, show=False)


# -----------------------------------------------------------------------------
# Utility helpers
# -----------------------------------------------------------------------------


def _read_json(path: Path, default: Any) -> Any:
    try:
        if not path.exists():
            return default
        return json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return default


def _read_jsonl(path: Path) -> list[dict[str, Any]]:
    if not path.exists():
        return []
    rows: list[dict[str, Any]] = []
    try:
        for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                item = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(item, dict):
                rows.append(item)
    except Exception:
        return []
    return rows


def _as_dict(value: Any) -> dict[str, Any]:
    return dict(value) if isinstance(value, dict) else {}


def _as_list(value: Any) -> list[dict[str, Any]]:
    if not isinstance(value, list):
        return []
    return [dict(x) for x in value if isinstance(x, dict)]


def _float(value: Any, default: float | None = None) -> float:
    try:
        if value in (None, "", "None"):
            raise ValueError
        return float(value)
    except (TypeError, ValueError):
        return float(default) if default is not None else math.nan


def _int(value: Any, default: int = 0) -> int:
    try:
        if value in (None, "", "None"):
            raise ValueError
        return int(float(value))
    except (TypeError, ValueError):
        return default


def _fmt(value: Any) -> str:
    if isinstance(value, bool):
        return "yes" if value else "no"
    try:
        if value in (None, "", "None"):
            return "—"
        x = float(value)
    except (TypeError, ValueError):
        return str(value) if value not in (None, "") else "—"
    if not math.isfinite(x):
        return "—"
    if abs(x) >= 100_000:
        return _compact(x)
    if abs(x) >= 100:
        return f"{x:,.0f}"
    if abs(x) >= 10:
        return f"{x:.2f}".rstrip("0").rstrip(".")
    return f"{x:.4f}".rstrip("0").rstrip(".")


def _compact(value: Any) -> str:
    try:
        x = float(value)
    except (TypeError, ValueError):
        return "—"
    sign = "-" if x < 0 else ""
    x = abs(x)
    if x >= 1_000_000:
        return f"{sign}{x / 1_000_000:.1f}M"
    if x >= 1_000:
        return f"{sign}{x / 1_000:.1f}k"
    return f"{sign}{x:.0f}"


def _clip(value: str, limit: int) -> str:
    value = " ".join((value or "").split())
    return value if len(value) <= limit else value[: limit - 1].rstrip() + "…"


def _run_num(run_id: str) -> int:
    m = re.search(r"(\d+)$", run_id or "")
    return int(m.group(1)) if m else 0


def _short_run(run_id: str) -> str:
    if not run_id:
        return "—"
    return run_id.replace("run_", "#")


def _timestamp_key(row: dict[str, Any]) -> float:
    for key in ["completed_at", "manifest_written_at", "created_at"]:
        ts = _parse_ts(row.get(key))
        if ts > 0:
            return ts
    return float(_run_num(str(row.get("run_id") or "")))


def _parse_ts(value: Any) -> float:
    if not value:
        return 0.0
    if isinstance(value, (int, float)):
        return float(value)
    raw = str(value).strip()
    if not raw:
        return 0.0
    try:
        # Accept both Z and +00:00 forms without adding dateutil.
        from datetime import datetime

        dt = datetime.fromisoformat(raw.replace("Z", "+00:00"))
        return dt.timestamp()
    except Exception:
        return 0.0


def _ago(start: float) -> str:
    delta = max(0.0, time.time() - start)
    if delta < 1:
        return "now"
    if delta < 60:
        return f"{delta:.0f}s"
    if delta < 3600:
        return f"{delta / 60:.0f}m"
    return f"{delta / 3600:.1f}h"


def _ago_ts(value: Any) -> str:
    ts = _parse_ts(value)
    if ts <= 0:
        return "time unknown"
    return _ago(ts)


def _short_json(event: dict[str, Any]) -> str:
    try:
        return _clip(json.dumps(event, sort_keys=True, default=str), 160)
    except Exception:
        return _clip(str(event), 160)


def main() -> None:
    parser = argparse.ArgumentParser(description="Read-only NiceGUI dashboard for AI Evolver arenas")
    parser.add_argument("--arena", default=".arena", help="arena state folder")
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8080)
    parser.add_argument("--poll-s", type=float, default=1.0, help="filesystem polling interval")
    parser.add_argument("--title", default="AI Evolver Live")
    args = parser.parse_args()
    run_dashboard(args.arena, host=args.host, port=args.port, poll_s=args.poll_s, title=args.title)


if __name__ == "__main__":
    main()
