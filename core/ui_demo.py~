def render_branch_svg(snapshot: ArenaSnapshot, selected_run_id: str | None = None) -> str:
    runs = snapshot.runs
    if not runs:
        return _empty_svg("No branches yet. Start `evolve` and this constellation will light up.")

    pareto = pareto_front(runs)
    latest = snapshot.latest_run.run_id if snapshot.latest_run else None
    best = snapshot.best_run.run_id if snapshot.best_run else None

    by_gen: dict[int, list[RunView]] = {}
    for run in runs:
        by_gen.setdefault(run.generation, []).append(run)
    for gen in by_gen:
        by_gen[gen].sort(key=lambda r: (-r.score, _run_num(r.run_id)))

    x_gap = 190
    y_gap = 92
    margin_x = 54
    margin_y = 50
    width = max(760, margin_x * 2 + x_gap * max(1, len(by_gen)))
    max_col = max((len(v) for v in by_gen.values()), default=1)
    height = max(360, margin_y * 2 + y_gap * max_col)

    coords: dict[str, tuple[float, float]] = {}
    for gen, rows in by_gen.items():
        x = margin_x + gen * x_gap
        base = height / 2 - (len(rows) - 1) * y_gap / 2
        for i, run in enumerate(rows):
            coords[run.run_id] = (x, base + i * y_gap)

    parts = [
        f'<svg viewBox="0 0 {width} {height}" class="evo-svg" role="img" aria-label="Evolution branch graph">',
        '<defs>',
        '<radialGradient id="nodeGlow" cx="45%" cy="35%" r="70%"><stop offset="0%" stop-color="#ffffff" stop-opacity="0.95"/><stop offset="45%" stop-color="#8b5cf6" stop-opacity="0.9"/><stop offset="100%" stop-color="#06b6d4" stop-opacity="0.95"/></radialGradient>',
        '<linearGradient id="edgeGrad" x1="0" x2="1"><stop offset="0%" stop-color="#22d3ee" stop-opacity="0.15"/><stop offset="100%" stop-color="#a78bfa" stop-opacity="0.75"/></linearGradient>',
        '</defs>',
        '<rect x="0" y="0" width="100%" height="100%" rx="26" class="svg-bg"/>',
    ]

    # Generation guide rails
    for gen in sorted(by_gen):
        x = margin_x + gen * x_gap
        parts.append(f'<line x1="{x:.1f}" y1="28" x2="{x:.1f}" y2="{height - 28}" class="gen-line"/>')
        parts.append(f'<text x="{x:.1f}" y="30" class="gen-label">GEN {gen}</text>')

    # Parent edges
    for run in runs:
        if not run.parent_id or run.parent_id not in coords or run.run_id not in coords:
            continue
        x1, y1 = coords[run.parent_id]
        x2, y2 = coords[run.run_id]
        mid = (x1 + x2) / 2
        parts.append(
            f'<path d="M{x1 + 18:.1f},{y1:.1f} C{mid:.1f},{y1:.1f} {mid:.1f},{y2:.1f} {x2 - 18:.1f},{y2:.1f}" class="evo-edge"/>'
        )

    for run in runs:
        x, y = coords[run.run_id]
        classes = ["evo-node"]
        if run.run_id == latest:
            classes.append("latest")
        if run.run_id == selected_run_id:
            classes.append("selected")
        if run.run_id in pareto:
            classes.append("pareto")
        if run.run_id == best:
            classes.append("best")
        if run.status != "succeeded":
            classes.append("failed" if run.status == "failed" else "unknown")

        title = html.escape(
            f"{run.run_id}\nstatus={run.status}\nscore={_fmt(run.score)}\nacc={_fmt(run.data.get('val_accuracy'))}\n{run.data.get('mutation_summary') or run.data.get('mutation_type') or ''}"
        )
        label = html.escape(_short_run(run.run_id))
        score = html.escape(_fmt(run.score))
        parts.extend(
            [
                f'<g class="{" ".join(classes)}">',
                f'<title>{title}</title>',
                f'<circle cx="{x:.1f}" cy="{y:.1f}" r="24" class="node-halo"/>',
                f'<circle cx="{x:.1f}" cy="{y:.1f}" r="15" class="node-core"/>',
                f'<text x="{x:.1f}" y="{y + 36:.1f}" class="node-label">{label}</text>',
                f'<text x="{x:.1f}" y="{y + 52:.1f}" class="node-score">{score}</text>',
                '</g>',
            ]
        )
    parts.append('</svg>')
    return "".join(parts)


def render_score_svg(runs: list[RunView]) -> str:
    rows = [r for r in runs if math.isfinite(r.score) and r.score > -998]
    if len(rows) < 2:
        return _empty_svg("Score skyline appears after two scored runs.", height=240)
    rows = sorted(rows, key=lambda r: (_timestamp_key(r.data), _run_num(r.run_id)))
    width, height = 900, 240
    left, right, top, bottom = 42, 24, 22, 38
    min_s = min(r.score for r in rows)
    max_s = max(r.score for r in rows)
    spread = max(max_s - min_s, 1e-9)

    def x_at(i: int) -> float:
        return left + i * (width - left - right) / max(1, len(rows) - 1)

    def y_at(score: float) -> float:
        return top + (max_s - score) * (height - top - bottom) / spread

    points = [(x_at(i), y_at(r.score), r) for i, r in enumerate(rows)]
    d = " ".join(("M" if i == 0 else "L") + f"{x:.1f},{y:.1f}" for i, (x, y, _) in enumerate(points))
    area = d + f" L{points[-1][0]:.1f},{height - bottom:.1f} L{points[0][0]:.1f},{height - bottom:.1f} Z"
    parts = [
        f'<svg viewBox="0 0 {width} {height}" class="score-svg" role="img" aria-label="Score over time">',
        '<defs><linearGradient id="scoreArea" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#38bdf8" stop-opacity="0.28"/><stop offset="100%" stop-color="#8b5cf6" stop-opacity="0.02"/></linearGradient></defs>',
        f'<rect x="0" y="0" width="{width}" height="{height}" rx="22" class="svg-bg"/>',
        f'<path d="{area}" fill="url(#scoreArea)"/>',
        f'<path d="{d}" class="score-line"/>',
        f'<text x="{left}" y="18" class="axis-text">best {_fmt(max_s)}</text>',
        f'<text x="{left}" y="{height - 10}" class="axis-text">low {_fmt(min_s)}</text>',
    ]
    for x, y, run in points:
        cls = "score-point best" if run.score == max_s else "score-point"
        parts.append(f'<circle cx="{x:.1f}" cy="{y:.1f}" r="4.5" class="{cls}"><title>{html.escape(run.run_id)} score={_fmt(run.score)}</title></circle>')
    parts.append('</svg>')
    return "".join(parts)


def _empty_svg(message: str, *, height: int = 330) -> str:
    safe = html.escape(message)
    return f'''<svg viewBox="0 0 900 {height}" class="evo-svg"><rect x="0" y="0" width="900" height="{height}" rx="28" class="svg-bg"/><text x="450" y="{height / 2:.0f}" text-anchor="middle" class="empty-svg-text">{safe}</text></svg>'''


