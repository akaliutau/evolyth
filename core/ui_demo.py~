@dataclass
class RunView:
    data: dict[str, Any]
    review: dict[str, Any] = field(default_factory=dict)
    mutation: dict[str, Any] = field(default_factory=dict)
    metrics: dict[str, Any] = field(default_factory=dict)
    events: list[dict[str, Any]] = field(default_factory=list)

    @property
    def run_id(self) -> str:
        return str(self.data.get("run_id") or "")

    @property
    def parent_id(self) -> str | None:
        value = self.data.get("parent_id")
        return str(value) if value not in (None, "", "None") else None

    @property
    def generation(self) -> int:
        return _int(self.data.get("generation"), 0)

    @property
    def score(self) -> float:
        return _float(self.data.get("score"), -999.0)

    @property
    def status(self) -> str:
        return str(self.data.get("status") or "unknown")


@dataclass
class ArenaSnapshot:
    arena: Path
    generated_at: float
    revision: int
    runs: list[RunView]
    queue: list[dict[str, Any]]
    audit_events: list[dict[str, Any]]
    touched_paths: list[str]

    @property
    def runs_by_id(self) -> dict[str, RunView]:
        return {r.run_id: r for r in self.runs if r.run_id}

    @property
    def latest_run(self) -> RunView | None:
        if not self.runs:
            return None
        return max(self.runs, key=lambda r: (_timestamp_key(r.data), _run_num(r.run_id)))

    @property
    def best_run(self) -> RunView | None:
        succeeded = [r for r in self.runs if r.status == "succeeded"]
        rows = succeeded or self.runs
        return max(rows, key=lambda r: r.score) if rows else None


class FileEventBus:
    """Tiny polling bus: turns arena file changes into immutable snapshots."""

    def __init__(self, arena: str | Path):
        self.arena = Path(arena).expanduser().resolve()
        self._fingerprint: tuple[tuple[str, int, int], ...] = ()
        self._snapshot = ArenaSnapshot(self.arena, time.time(), 0, [], [], [], [])
        self._revision = 0

    @property
    def snapshot(self) -> ArenaSnapshot:
        return self._snapshot

    def poll(self, *, force: bool = False) -> tuple[ArenaSnapshot, bool]:
        fingerprint = self._scan_fingerprint()
        if not force and fingerprint == self._fingerprint:
            return self._snapshot, False
        self._fingerprint = fingerprint
        self._revision += 1
        self._snapshot = ArenaReader(self.arena).read(revision=self._revision)
        return self._snapshot, True

    def _scan_fingerprint(self) -> tuple[tuple[str, int, int], ...]:
        paths: list[Path] = []
        for rel in ["queue.json", "evolution.jsonl"]:
            p = self.arena / rel
            if p.exists():
                paths.append(p)
        runs_dir = self.arena / "runs"
        if runs_dir.exists():
            for name in ["manifest.json", "metrics.json", "events.jsonl", "ds_review.json", "mutation.json", "stdout.txt", "stderr.txt"]:
                paths.extend(runs_dir.glob(f"*/{name}"))
        fp: list[tuple[str, int, int]] = []
        for p in sorted(set(paths)):
            try:
                st = p.stat()
            except FileNotFoundError:
                continue
            fp.append((str(p.relative_to(self.arena)), st.st_mtime_ns, st.st_size))
        return tuple(fp)


class ArenaReader:
    def __init__(self, arena: str | Path):
        self.arena = Path(arena).expanduser().resolve()

    def read(self, *, revision: int) -> ArenaSnapshot:
        self.arena.mkdir(parents=True, exist_ok=True)
        audit_events = _read_jsonl(self.arena / "evolution.jsonl")[-250:]
        queue = _as_list(_read_json(self.arena / "queue.json", []))
        runs = self._read_runs(audit_events)
        touched = [str(p.relative_to(self.arena)) for p in self._interesting_paths()]
        return ArenaSnapshot(
            arena=self.arena,
            generated_at=time.time(),
            revision=revision,
            runs=runs,
            queue=sorted(queue, key=lambda r: _float(r.get("priority"), 0.0), reverse=True),
            audit_events=audit_events,
            touched_paths=touched,
        )

    def _read_runs(self, audit_events: list[dict[str, Any]]) -> list[RunView]:
        rows: dict[str, dict[str, Any]] = {}

        # Fall back to the audit log if LanceDB is unavailable and/or manifests are incomplete.
        for event in audit_events:
            if event.get("event") == "run_registered" and event.get("run_id"):
                rows[str(event["run_id"])] = {k: v for k, v in event.items() if k != "event"}

        runs_dir = self.arena / "runs"
        if runs_dir.exists():
            for run_dir in sorted(p for p in runs_dir.iterdir() if p.is_dir()):
                run_id = run_dir.name
                manifest = _as_dict(_read_json(run_dir / "manifest.json", {}))
                metrics = _as_dict(_read_json(run_dir / "metrics.json", {}))
                mutation = _as_dict(_read_json(run_dir / "mutation.json", {}))
                review = _as_dict(_read_json(run_dir / "ds_review.json", {}))

                row = dict(rows.get(run_id, {}))
                row.update({k: v for k, v in manifest.items() if k != "vector"})
                row.setdefault("run_id", run_id)
                row.setdefault("artifact_path", str(run_dir))
                row.setdefault("metrics_path", str(run_dir / "metrics.json"))
                row.setdefault("events_path", str(run_dir / "events.jsonl"))
                row.setdefault("model_path", str(run_dir / "model.py"))
                row.setdefault("summary_path", str(run_dir / "run_summary.md"))

                # Fill gaps from metrics/mutation/review without hiding manifest values.
                for key in [
                    "status",
                    "score",
                    "val_accuracy",
                    "accuracy",
                    "val_loss",
                    "parameter_count",
                    "params",
                    "model_bytes",
                    "latency_ms",
                    "train_seconds",
                    "dry_run_passed",
                    "error_type",
                    "observation",
                ]:
                    if row.get(key) in (None, "") and key in metrics:
                        row[key] = metrics[key]
                if row.get("val_accuracy") in (None, "") and metrics.get("accuracy") is not None:
                    row["val_accuracy"] = metrics.get("accuracy")
                if row.get("parameter_count") in (None, "") and metrics.get("params") is not None:
                    row["parameter_count"] = metrics.get("params")
                if row.get("mutation_type") in (None, "") and mutation.get("mutation_type"):
                    row["mutation_type"] = mutation.get("mutation_type")
                if row.get("mutation_summary") in (None, "") and mutation.get("mutation_summary"):
                    row["mutation_summary"] = mutation.get("mutation_summary")
                if row.get("hypothesis") in (None, "") and mutation.get("hypothesis"):
                    row["hypothesis"] = mutation.get("hypothesis")
                if review:
                    row.setdefault("observation", review.get("observation"))
                    row.setdefault("next_belief", review.get("next_belief"))

                rows[run_id] = row

        run_views: list[RunView] = []
        for run_id, row in rows.items():
            run_dir = Path(str(row.get("artifact_path") or self.arena / "runs" / run_id))
            review = _as_dict(_read_json(run_dir / "ds_review.json", {}))
            mutation = _as_dict(_read_json(run_dir / "mutation.json", {}))
            metrics = _as_dict(_read_json(run_dir / "metrics.json", {}))
            events = _read_jsonl(run_dir / "events.jsonl")[-80:]
            run_views.append(RunView(data=row, review=review, mutation=mutation, metrics=metrics, events=events))

        return sorted(run_views, key=lambda r: (_timestamp_key(r.data), _run_num(r.run_id)))

    def _interesting_paths(self) -> Iterable[Path]:
        for rel in ["queue.json", "evolution.jsonl"]:
            p = self.arena / rel
            if p.exists():
                yield p
        runs_dir = self.arena / "runs"
        if not runs_dir.exists():
            return
        for name in ["manifest.json", "metrics.json", "events.jsonl", "ds_review.json", "mutation.json"]:
            yield from runs_dir.glob(f"*/{name}")


